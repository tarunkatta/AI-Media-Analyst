# API Gateway (AWS Console → API Gateway → your API → Stages → prod → Invoke URL)
VITE_API_BASE_URL=

# Firebase (Firebase Console → Project Settings → Your Apps → Web App → firebaseConfig)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# AWS Lambda env vars (set these in AWS Console → Lambda → Configuration → Environment variables)
# S3_BUCKET_NAME=your-bucket-name          ← for get_upload_url and start_transcription
# ASSEMBLYAI_API_KEY=your-key-here         ← for start_transcription and get_transcript
